---
const navLinks = [
  { href: '/projects', label: 'projects' },
  { href: '/writing', label: 'writing' },
];

const pathname = Astro.url.pathname;
---

<header>
  <div class="container">
    <nav>
      <a href="/" class="nav-brand">fulvio.sh</a>

      <ul class="nav-links">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="nav-link"
              aria-current={pathname.startsWith(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}

        <li>
          <button
            class="theme-toggle"
            data-theme-toggle
            aria-label="Toggle theme"
          >
            <span class="icon-sun" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
            </span>
            <span class="icon-moon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
            </span>
          </button>
        </li>
      </ul>
    </nav>
  </div>
</header>