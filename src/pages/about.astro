---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const stack = {
  languages: ['Python', 'SQL', 'TypeScript'],
  backend: ['FastAPI', 'Docker', 'AWS', 'GitHub Actions'],
  data: ['PySpark', 'Airflow', 'Pandas'],
  ai: ['LangChain', 'LangGraph', 'RAG', 'Scikit-Learn'],
};
---

<Base title="About — Fulvio Favilla" description="Software Engineer based in São Paulo.">
  <Header />

  <main>
    <section class="container">
      <div class="page-header">
        <div class="meta">about</div>
        <h1>Fulvio Favilla</h1>
      </div>

      <div class="about-grid">
        <div class="about-bio">
          <p class="intro">
            Software Engineer based in São Paulo, Brazil. Background in Electrical Engineering
            and Data Engineering.
          </p>
          <p>
            I build things that are useful first, interesting second. Most of my work lives at the
            intersection of data, AI, and security.
          </p>

          <div class="contact-links">
            <a href="https://github.com/fulviofavilla" class="nav-link" target="_blank" rel="noopener noreferrer">github →</a>
            <a href="mailto:fulvio@fulvio.sh" class="nav-link">email →</a>
          </div>
        </div>

        <div class="about-stack">
          {Object.entries(stack).map(([category, items]) => (
            <div class="stack-group">
              <div class="stack-label meta">{category}</div>
              <div class="tags">
                {items.map((item) => <span class="tag">{item}</span>)}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  .page-header {
    padding-top: var(--space-16);
    padding-bottom: var(--space-12);
  }

  .page-header .meta {
    margin-bottom: var(--space-4);
  }

  .page-header h1 {
    margin: 0;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    padding-bottom: var(--space-16);
    align-items: start;
  }

  .about-bio p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-5);
  }

  .about-bio p.intro {
    margin-bottom: var(--space-8);
  }

  .about-bio p:last-of-type {
    margin-bottom: var(--space-8);
  }

  .contact-links {
    display: flex;
    gap: var(--space-6);
  }

  .stack-group {
    margin-bottom: var(--space-8);
  }

  .stack-group:last-child {
    margin-bottom: 0;
  }

  .stack-label {
    margin-bottom: var(--space-3);
    color: var(--text-faint);
  }

  @media (max-width: 680px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }
  }
</style>