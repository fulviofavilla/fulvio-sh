---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base title="About" description="Software Engineer. Backend systems, infrastructure, and security.">
  <Header />

  <main>
    <section class="container">
      <div class="page-header">
        <div class="meta">about</div>
        <h1>Fulvio Favilla</h1>
      </div>

      <div class="about-bio">
        <p>
          I build backend systems and the infrastructure around them, with a preference
          for tools that have a clear purpose and code that goes beyond the happy path.
        </p>
        <p>
          Security has become a growing interest. What pulls me in is how much you need
          to understand a system before you can find where it breaks.
        </p>
        <p>
          I have a soft spot for open-source. Code that anyone can read, question, and improve.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  .page-header {
    padding-top: var(--space-16);
    padding-bottom: var(--space-12);
  }

  .page-header .meta {
    margin-bottom: var(--space-4);
  }

  .page-header h1 {
    margin: 0;
  }

  .about-bio {
    max-width: 600px;
    padding-bottom: var(--space-16);
  }

  .about-bio p {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-6);
  }
</style>