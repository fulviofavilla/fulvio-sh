---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const stack = [
  'Python', 'SQL', 'AWS', 'FastAPI', 'Docker',
  'LangChain', 'LangGraph', 'RAG', 'PySpark', 'Airflow',
];

const featured = [
  {
    name: 'ResumeRadar',
    description: 'RAG-powered resume analysis and matching engine. Built with LangGraph, FastAPI, and Docker.',
    tags: ['python', 'langgraph', 'rag', 'fastapi'],
    href: 'https://github.com/fulviofavilla/resume-radar',
    status: 'in progress',
  },
  {
    name: 'Security Analyzer',
    description: 'Automated security analysis for GitHub repositories using LangGraph and static analysis tools.',
    tags: ['python', 'langgraph', 'github api', 'security'],
    href: 'https://github.com/fulviofavilla/security-analyzer',
    status: 'in progress',
  },
];
---

<Base title="Fulvio Favilla" description="Software Engineer specializing in Data Engineering and LLM/AI Agents.">
  <Header />

  <main>
    <!-- Hero -->
    <section class="hero container">
      <div class="hero-label meta">software engineer</div>
      <h1>Fulvio Favilla</h1>
      <p class="lead">
        I design and build systems that make data useful.
      </p>
      <div class="hero-links">
        <a href="/projects" class="nav-link">projects →</a>
        <a href="/writing" class="nav-link">writing →</a>
        <a
          href="https://github.com/fulviofavilla"
          class="nav-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          github →
        </a>
      </div>
    </section>

    <!-- Stack -->
    <section class="section container">
      <h2 class="section-label meta">stack</h2>
      <div class="tags">
        {stack.map((item) => (
          <span class="tag">{item}</span>
        ))}
      </div>
    </section>

    <!-- Featured projects -->
    <section class="section container">
      <h2 class="section-label meta">featured projects</h2>
      <div class="card-grid">
        {featured.map(({ name, description, tags, href, status }) => (
          <a href={href} class="card card-link" target="_blank" rel="noopener noreferrer">
            <div class="card-header">
              <span class="card-name">{name}</span>
              <span class="tag">{status}</span>
            </div>
            <p class="card-description">{description}</p>
            <div class="tags" style="margin-top: var(--space-4);">
              {tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </a>
        ))}
      </div>
      <div style="margin-top: var(--space-6);">
        <a href="/projects" class="nav-link">all projects →</a>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  /* Hero */
  .hero {
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
  }

  .hero-label {
    margin-bottom: var(--space-4);
  }

  .hero h1 {
    margin-bottom: var(--space-6);
  }

  .hero .lead {
    max-width: 520px;
    margin-bottom: var(--space-8);
  }

  .hero-links {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  /* Sections */
  .section {
    padding-bottom: var(--space-16);
  }

  .section-label {
    margin-bottom: var(--space-6);
  }

  /* Card link override */
  .card-link {
    display: block;
    text-decoration: none;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .card-name {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text);
    letter-spacing: 0.02em;
  }

  .card-description {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0;
  }
</style>