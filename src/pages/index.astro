---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WritingList from '../components/WritingList.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const writeups = await getCollection('writeups', ({ data }) => !data.draft);

const recentWriting = [
  ...posts.map((p) => ({ ...p, type: 'blog' as const, href: `/blog/${p.id}` })),
  ...writeups.map((w) => ({ ...w, type: 'writeup' as const, href: `/writeups/${w.id}` })),
]
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const featured = [
  {
    name: 'ResumeRadar',
    description: 'AI agent that analyzes your resume against real tech job postings, surfaces skill gaps, and rewrites weak bullets.',
    tags: ['python', 'langgraph', 'fastapi', 'chromadb', 'docker'],
    href: 'https://github.com/fulviofavilla/resume-radar',
    status: 'in progress',
  },
];
---

<Base title="Fulvio Favilla" description="Software Engineer. Backend systems, infrastructure, and security.">
  <Header />

  <main>
    <!-- Hero -->
    <section class="hero container">
      <div class="hero-label meta">software engineer</div>
      <h1>Fulvio Favilla</h1>
      <p class="lead">
        Building things and writing about what I find along the way.
      </p>
    </section>

    <!-- Featured projects -->
    <section class="section container">
      <h2 class="section-label meta">featured projects</h2>
      <div class="card-grid">
        {featured.map(({ name, description, tags, href, status }) => (
          <a href={href} class="card card-link" target="_blank" rel="noopener noreferrer">
            <div class="card-header">
              <span class="card-name">{name}</span>
              <span class="tag">{status}</span>
            </div>
            <p class="card-description">{description}</p>
            <div class="tags" style="margin-top: var(--space-4);">
              {tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </a>
        ))}
      </div>
      <div style="margin-top: var(--space-6);">
        <a href="/projects" class="nav-link">all projects →</a>
      </div>
    </section>

    <!-- Recent writing -->
    {recentWriting.length > 0 && (
      <section class="section container">
        <h2 class="section-label meta">recent writing</h2>
        <WritingList entries={recentWriting} />
        <div style="margin-top: var(--space-6);">
          <a href="/writing" class="nav-link">all writing →</a>
        </div>
      </section>
    )}
  </main>

  <Footer />
</Base>

<style>
  /* Hero */
  .hero {
    padding-top: var(--space-24);
    padding-bottom: var(--space-16);
  }

  .hero-label {
    margin-bottom: var(--space-4);
  }

  .hero h1 {
    margin-bottom: var(--space-6);
    line-height: 1.05;
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  /* Sections */
  .section {
    padding-bottom: var(--space-16);
  }

  .section-label {
    margin-bottom: var(--space-6);
  }

  /* Card link override */
  .card-link {
    display: block;
    text-decoration: none;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .card-name {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text);
    letter-spacing: 0.02em;
  }

  .card-description {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0;
  }
</style>