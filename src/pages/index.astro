---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WritingList from '../components/WritingList.astro';
import ProjectCard from '../components/ProjectCard.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const writeups = await getCollection('writeups', ({ data }) => !data.draft);

const recentWriting = [
  ...posts.map((p) => ({ ...p, type: 'blog' as const, href: `/blog/${p.id}` })),
  ...writeups.map((w) => ({ ...w, type: 'writeup' as const, href: `/writeups/${w.id}` })),
]
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const featured = [
  {
    name: 'ResumeRadar',
    description: 'LLM pipeline (LangGraph) that matches resumes against live job-market data, with semantic gap analysis using embeddings and ChromaDB.',
    tags: ['fastapi', 'langgraph', 'chromadb', 'redis', 'docker'],
    href: 'https://github.com/fulviofavilla/resume-radar',
    status: 'v1',
  },
  {
    name: 'CVD Prediction',
    description: 'ML pipeline comparing five classifiers for cardiovascular disease prediction, with a distributed ECL/HPCC implementation. Winner of the 2023 HPCC Systems Poster Contest.',
    tags: ['python', 'scikit-learn', 'ecl', 'hpcc'],
    href: 'https://github.com/fulviofavilla/cvd-prediction-ml',
    status: '2023',
  },
];
---

<Base title="Fulvio Favilla" description="Software and electrical engineering: backend systems, energy data, and critical infrastructure.">
  <Header />

  <main>
    <!-- Hero -->
    <section class="hero container">
      <div class="hero-label meta">software × electrical engineering</div>
      <h1>Fulvio Favilla</h1>
      <p class="lead">
        Backend and data engineer with an electrical engineering degree.
        Building software for the physical world: power systems, energy
        data, and the infrastructure behind it.
      </p>
    </section>

    <!-- Featured projects -->
    <section class="section container">
      <h2 class="section-label meta">featured projects</h2>
      <div class="card-grid">
        {featured.map((project) => <ProjectCard {...project} />)}
      </div>
      <div style="margin-top: var(--space-6);">
        <a href="/projects" class="nav-link">all projects →</a>
      </div>
    </section>

    <!-- Recent writing -->
    {recentWriting.length > 0 && (
      <section class="section container">
        <h2 class="section-label meta">recent writing</h2>
        <WritingList entries={recentWriting} />
        <div style="margin-top: var(--space-6);">
          <a href="/writing" class="nav-link">all writing →</a>
        </div>
      </section>
    )}
  </main>

  <Footer />
</Base>

<style>
  /* Hero */
  .hero {
    padding-top: var(--space-24);
    padding-bottom: var(--space-16);
  }

  .hero-label {
    margin-bottom: var(--space-4);
  }

  .hero h1 {
    margin-bottom: var(--space-6);
    line-height: 1.05;
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  /* Sections */
  .section {
    padding-bottom: var(--space-16);
  }

  .section-label {
    margin-bottom: var(--space-6);
  }
</style>