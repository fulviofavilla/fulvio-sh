---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = [
  {
    name: 'ResumeRadar',
    description: 'AI agent that analyzes your resume against real tech job postings, surfaces skill gaps, and rewrites weak bullets.',
    tags: ['python', 'langgraph', 'fastapi', 'chromadb', 'docker'],
    href: 'https://github.com/fulviofavilla/resume-radar',
    status: 'in progress',
  },
];
---

<Base title="Projects" description="Things I'm building.">
  <Header />

  <main>
    <section class="container">
      <div class="page-header">
        <div class="meta">projects</div>
      </div>

      <div class="card-grid">
        {projects.map((project) => <ProjectCard {...project} />)}
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  .page-header {
    padding-top: var(--space-16);
    padding-bottom: var(--space-6);
  }

  .page-header .meta {
    margin-bottom: var(--space-4);
  }

  .card-grid {
    padding-bottom: var(--space-16);
  }
</style>