---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = [
  {
    name: 'ResumeRadar',
    description: 'LLM pipeline (LangGraph) that matches resumes against live job-market data, with semantic gap analysis using embeddings and ChromaDB.',
    tags: ['fastapi', 'langgraph', 'chromadb', 'redis', 'docker'],
    href: 'https://github.com/fulviofavilla/resume-radar',
    status: 'v1',
  },
  {
    name: 'CVD Prediction',
    description: 'ML pipeline comparing five classifiers for cardiovascular disease prediction, with a distributed ECL/HPCC implementation. Winner of the 2023 HPCC Systems Poster Contest.',
    tags: ['python', 'scikit-learn', 'ecl', 'hpcc'],
    href: 'https://github.com/fulviofavilla/cvd-prediction-ml',
    status: '2023',
  },
  {
    name: 'servepass',
    description: 'Zero-dependency LAN file server with token auth. Like python -m http.server, but not open to the whole network. Published on PyPI.',
    tags: ['python', 'stdlib', 'http', 'pypi'],
    href: 'https://github.com/fulviofavilla/servepass',
    status: 'v0.2.0',
  },
];
---

<Base title="Projects" description="Things I'm building.">
  <Header />

  <main>
    <section class="container">
      <div class="page-header">
        <div class="meta">projects</div>
      </div>

      <div class="card-grid">
        {projects.map((project) => <ProjectCard {...project} />)}
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  .page-header {
    padding-top: var(--space-16);
    padding-bottom: var(--space-6);
  }

  .page-header .meta {
    margin-bottom: var(--space-4);
  }

  .card-grid {
    padding-bottom: var(--space-16);
  }
</style>