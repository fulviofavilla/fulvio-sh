---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  platform?: string;
  difficulty?: 'easy' | 'medium' | 'hard';
  readingTime?: number;
  slug: string;
}

const { title, description, date, tags = [], platform, difficulty, readingTime, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});

const isoDate = date.toISOString().split('T')[0];
---

<Base title={title} description={description} ogImage={slug ? `/og/${slug}.png` : undefined}>
  <Header />

  <main>
    <article class="container">
      <!-- Header -->
      <header class="post-header">
        <div class="post-meta">
          <time datetime={isoDate} class="meta">{formattedDate}</time>

          {platform && (
            <span class="meta" style="color: var(--text-faint);">·</span>
            <span class="meta">{platform}</span>
          )}

          {difficulty && (
            <span class="meta" style="color: var(--text-faint);">·</span>
            <span class={`meta difficulty--${difficulty}`}>{difficulty}</span>
          )}

          {readingTime && (
            <span class="meta" style="color: var(--text-faint);">·</span>
            <span class="meta">{readingTime} min read</span>
          )}
        </div>

        <h1 class="post-title">{title}</h1>
        <p class="lead">{description}</p>

        {tags.length > 0 && (
          <div class="tags" style="margin-top: var(--space-6);">
            {tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <hr class="post-divider" />

      <!-- Content -->
      <div class="prose">
        <slot />
      </div>
    </article>
  </main>

  <Footer />
</Base>

<style>
  .post-header {
    padding-top: var(--space-12);
    padding-bottom: var(--space-8);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .post-title {
    margin-bottom: var(--space-4);
  }

  .post-divider {
    border: none;
    border-top: 1px solid var(--border-subtle);
    margin: 0 0 var(--space-12);
  }

  /* Difficulty colors — subtle, no accent */
  .difficulty--easy   { color: var(--text-muted); }
  .difficulty--medium { color: var(--text-muted); }
  .difficulty--hard   { color: var(--text-muted); }

  /* Prose spacing within article */
  .prose {
    padding-bottom: var(--space-16);
  }
</style>